# ============================================================================
# FLANCE - Environment Variables Template
# ============================================================================
# Copie este arquivo para .env e preencha com suas configurações
# IMPORTANTE: NUNCA commite .env em git - use apenas .env.local para dev
# ============================================================================

# ============================================================================
# NODE ENVIRONMENT
# ============================================================================
NODE_ENV=development
# Opções: development | staging | production

# ============================================================================
# DATABASE - PostgreSQL
# ============================================================================
DATABASE_URL="postgresql://postgres:password@localhost:5432/flance"
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Exemplo com Supabase: postgresql://postgres:[PASSWORD]@db.[ID].supabase.co:5432/postgres?sslmode=require
# Para desenvolvimento local: postgresql://postgres:password@localhost:5432/flance

# ============================================================================
# JWT - JSON Web Tokens
# ============================================================================
JWT_SECRET="your-secret-key-minimum-32-characters-long-change-in-production"
# Gere com: openssl rand -base64 32
# ⚠️ CRÍTICO: Use mínimo 32 caracteres em produção
# 💡 Dica: Altere a cada 6 meses em produção

JWT_EXPIRATION="7d"
# Formato: 1h, 24h, 7d, 30d, etc (veja jsonwebtoken docs)

JWT_REFRESH_SECRET="your-refresh-secret-key-minimum-32-characters-long"
JWT_REFRESH_EXPIRATION="30d"

JWT_RESET_EXPIRATION="15m"
# Token de reset de senha expira em 15 minutos

# ============================================================================
# CORS - Cross-Origin Resource Sharing
# ============================================================================
CORS_ORIGIN="http://localhost:3000"
# Em produção: https://seu-dominio.com
# ⚠️ NUNCA use "*" em produção - deixa API aberta para qualquer origem
# Para múltiplos domínios, use: https://seu-dominio.com,https://www.seu-dominio.com

# ============================================================================
# API SERVER
# ============================================================================
PORT=3001
API_HOST=0.0.0.0
API_URL="http://localhost:3001"
# Em produção: https://api.seu-dominio.com

# ============================================================================
# WEB (Frontend Next.js)
# ============================================================================
WEB_BASE_URL="http://localhost:3000"
# Em produção: https://seu-dominio.com

NEXT_PUBLIC_API_URL="http://localhost:3001"
# ⚠️ NEXT_PUBLIC_* expõem a variável no cliente (browser)
# Deve ser acessível do navegador do usuário

# ============================================================================
# EMAIL - SMTP
# ============================================================================
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="seu-email@gmail.com"
# Para Gmail: ative "App Passwords" em
# https://myaccount.google.com/apppasswords

SMTP_PASS="seu-app-password-16-caracteres"
SMTP_FROM="noreply@flance.com"
# Email que aparece como remetente

# Exemplo com SendGrid:
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=SG.seu-sendgrid-api-key

# ============================================================================
# STRIPE - Pagamentos (v0.2.0)
# ============================================================================
STRIPE_SECRET_KEY="sk_test_xxx"
STRIPE_WEBHOOK_SECRET="whsec_test_xxx"
STRIPE_CONNECT_CLIENT_ID="ca_test_xxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxx"
# Keys de teste em https://dashboard.stripe.com/test/apikeys

# ============================================================================
# REDIS - Cache (Opcional)
# ============================================================================
# REDIS_URL="redis://localhost:6379"
# REDIS_PASSWORD="redis-password"
# Use em produção para cache e session management

# ============================================================================
# LOGGING - Winston
# ============================================================================
LOG_LEVEL="debug"
# Opções: error | warn | info | debug | verbose
# Em produção: info ou warn

LOG_FORMAT="pretty"
# Opções: json | pretty
# json para produção (machine-readable), pretty para dev

# ============================================================================
# RATE LIMITING
# ============================================================================
RATE_LIMIT_ENABLED="true"
RATE_LIMIT_WINDOW_MS=900000
# Janela de tempo em ms (padrão 15 min)

RATE_LIMIT_MAX_REQUESTS=100
# Máximo de requests por janela por IP

# ============================================================================
# AI MATCHING ENGINE (v0.2.0)
# ============================================================================
# OPENAI_API_KEY="sk-xxx"
# OPENAI_MODEL="gpt-4-turbo"
# Obtenha em https://platform.openai.com/api-keys

# ============================================================================
# AUTHENTICATION (Opcional - OAuth)
# ============================================================================
# GOOGLE_CLIENT_ID="xxx.apps.googleusercontent.com"
# GOOGLE_CLIENT_SECRET="xxx"
# GITHUB_CLIENT_ID="xxx"
# GITHUB_CLIENT_SECRET="xxx"
# NEXTAUTH_SECRET="use openssl rand -base64 32"

# ============================================================================
# AWS S3 - Upload de Arquivos (v0.2.0)
# ============================================================================
# AWS_ACCESS_KEY_ID="sua-access-key"
# AWS_SECRET_ACCESS_KEY="sua-secret-key"
# AWS_REGION="us-east-1"
# AWS_S3_BUCKET="flance-uploads"

# ============================================================================
# OBSERVABILITY (Produção)
# ============================================================================
# SENTRY_DSN="https://seu-sentry-dsn@sentry.io/xxx"
# DATADOG_API_KEY="seu-datadog-key"

# ============================================================================
# OUTROS
# ============================================================================
NEXTAUTH_SECRET="change-me-to-random-32-chars"
# Para NextAuth.js se usar autenticação adicional
